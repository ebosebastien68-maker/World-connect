{
  "compilerOptions": {
    "target": "ESNext",                   
    "module": "ESNext",                   
    "jsx": "react-jsx",                   
    "strict": true,                        
    "moduleResolution": "node",           
    "esModuleInterop": true,              
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,                 
    "resolveJsonModule": true,            
    "isolatedModules": true,              
    "baseUrl": "src",                     
    "paths": {                            
      "@/*": ["*"]                        
    }
  },
  "include": ["src"],                     
  "exclude": ["node_modules", "dist"]     
}
